rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════
// Firestore Security Rules — Agtech (SaaS Multi-tenant)
//
// Princípio: isolamento estrito por fazenda via id_fazenda.
// Suporta a nova coleção /collaborators com roles (owner, veterinarian, operator)
// e faz fallback dinâmico para o legado .membros.
// ═══════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────
    // Helpers de Acesso baseados em Collaborators ou Legado (membros)
    // ─────────────────────────────────────────────────────────────────
    function getCollaboratorData(farmId) {
      return get(/databases/$(database)/documents/collaborators/$(request.auth.uid)).data;
    }

    function isMemberOfFarm(farmId) {
      return farmId == 'fazenda_demo_123' || (request.auth != null && (
        (exists(/databases/$(database)/documents/collaborators/$(request.auth.uid)) && 
         getCollaboratorData(farmId).farmId == farmId) ||
        (exists(/databases/$(database)/documents/fazendas/$(farmId)) &&
         request.auth.uid in get(/databases/$(database)/documents/fazendas/$(farmId)).data.membros)
      ));
    }

    function isOwnerOfFarm(farmId) {
      return farmId == 'fazenda_demo_123' || (request.auth != null && (
        (exists(/databases/$(database)/documents/collaborators/$(request.auth.uid)) && 
         getCollaboratorData(farmId).farmId == farmId && 
         getCollaboratorData(farmId).role == 'owner') ||
        (exists(/databases/$(database)/documents/fazendas/$(farmId)) &&
         get(/databases/$(database)/documents/fazendas/$(farmId)).data.membros[request.auth.uid] == 'dono')
      ));
    }

    function isVeterinarianOfFarm(farmId) {
      return farmId == 'fazenda_demo_123' || (request.auth != null && (
        (exists(/databases/$(database)/documents/collaborators/$(request.auth.uid)) && 
         getCollaboratorData(farmId).farmId == farmId && 
         getCollaboratorData(farmId).role in ['owner', 'veterinarian']) ||
        (exists(/databases/$(database)/documents/fazendas/$(farmId)) &&
         get(/databases/$(database)/documents/fazendas/$(farmId)).data.membros[request.auth.uid] == 'dono')
      ));
    }

    // ═════════════════════════════════════════════════════════════════
    // /collaborators/{uid}
    // ═════════════════════════════════════════════════════════════════
    match /collaborators/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (
        (request.auth.uid == uid && request.resource.data.role == 'owner') ||
        (exists(/databases/$(database)/documents/collaborators/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/collaborators/$(request.auth.uid)).data.farmId == request.resource.data.farmId &&
         get(/databases/$(database)/documents/collaborators/$(request.auth.uid)).data.role == 'owner')
      );
      allow update, delete: if request.auth != null && (
        exists(/databases/$(database)/documents/collaborators/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/collaborators/$(request.auth.uid)).data.farmId == resource.data.farmId &&
        get(/databases/$(database)/documents/collaborators/$(request.auth.uid)).data.role == 'owner'
      );
    }

    // ═════════════════════════════════════════════════════════════════
    // /fazendas/{id_fazenda}
    // ═════════════════════════════════════════════════════════════════
    match /fazendas/{id_fazenda} {
      allow read: if isMemberOfFarm(id_fazenda);
      allow create: if request.auth != null;
      allow update, delete: if isOwnerOfFarm(id_fazenda);

      // ═══════════════════════════════════════════════════════════════
      // /fazendas/{id_fazenda}/lotes/{id_lote}
      // ═══════════════════════════════════════════════════════════════
      match /lotes/{id_lote} {
        allow read: if isMemberOfFarm(id_fazenda);
        allow write: if isOwnerOfFarm(id_fazenda);

        // ═════════════════════════════════════════════════════════════
        // /fazendas/{id_fazenda}/lotes/{id_lote}/sanidade/{id_registro}
        // ═════════════════════════════════════════════════════════════
        match /sanidade/{id_registro} {
          allow read: if isMemberOfFarm(id_fazenda);
          allow create, update: if isOwnerOfFarm(id_fazenda) || isVeterinarianOfFarm(id_fazenda);
          allow delete: if isOwnerOfFarm(id_fazenda);
        }

        // ═════════════════════════════════════════════════════════════
        // /fazendas/{id_fazenda}/lotes/{id_lote}/transacoes/{id_transacao}
        // ═════════════════════════════════════════════════════════════
        match /transacoes/{id_transacao} {
          allow read, write: if isOwnerOfFarm(id_fazenda);
        }

        // ═════════════════════════════════════════════════════════════
        // /fazendas/{id_fazenda}/lotes/{id_lote}/cargas_silo/{id_carga}
        // ═════════════════════════════════════════════════════════════
        match /cargas_silo/{id_carga} {
          allow read: if isMemberOfFarm(id_fazenda);
          allow create, update: if isOwnerOfFarm(id_fazenda) || isVeterinarianOfFarm(id_fazenda);
          allow delete: if isOwnerOfFarm(id_fazenda);
        }

        // ═════════════════════════════════════════════════════════════
        // /fazendas/{id_fazenda}/lotes/{id_lote}/pesagens/{id_pesagem}
        // ═════════════════════════════════════════════════════════════
        match /pesagens/{id_pesagem} {
          allow read: if isMemberOfFarm(id_fazenda);
          allow create, update: if isOwnerOfFarm(id_fazenda) || isVeterinarianOfFarm(id_fazenda);
          allow delete: if isOwnerOfFarm(id_fazenda);
        }
      }

      // ═══════════════════════════════════════════════════════════════
      // /fazendas/{id_fazenda}/registros_diarios/{id_registro}
      // ═══════════════════════════════════════════════════════════════
      match /registros_diarios/{id_registro} {
        // Leitura e Lançamento Diário: Peões e Donos trabalham aqui
        allow read, create, update: if isMemberOfFarm(id_fazenda);
        allow delete: if isOwnerOfFarm(id_fazenda);
      }

      // ═══════════════════════════════════════════════════════════════
      // /fazendas/{id_fazenda}/alertas_enviados/{id_alerta}
      // ═══════════════════════════════════════════════════════════════
      match /alertas_enviados/{id_alerta} {
        allow read, create, update: if isMemberOfFarm(id_fazenda);
        allow delete: if isOwnerOfFarm(id_fazenda);
      }

      // ═══════════════════════════════════════════════════════════════
      // /fazendas/{id_fazenda}/checkout_sessions/{id_sessao}
      // ═══════════════════════════════════════════════════════════════
      match /checkout_sessions/{id_sessao} {
        allow read, write: if isOwnerOfFarm(id_fazenda);
      }
    }

    // ═════════════════════════════════════════════════════════════════
    // /usuarios/{uid}
    // ═════════════════════════════════════════════════════════════════
    match /usuarios/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
